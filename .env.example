# Option 1 (recommended, free): GitHub personal access token
# Create one at https://github.com/settings/tokens with no extra scopes needed
GITHUB_TOKEN=your_github_token_here

# Option 2: OpenAI API key (requires billing)
# OPENAI_API_KEY=your_openai_api_key_here

# Model name (works with both GitHub Models and OpenAI)
AI_MODEL=gpt-4o-mini

RATE_LIMIT_WINDOW_SECONDS=300
RATE_LIMIT_MAX_REQUESTS=5

# Comma-separated list of frontend origins allowed to call this API.
# Use * only for quick testing, not for strict production setups.
# Example: CORS_ORIGINS=https://yourname.github.io,http://127.0.0.1:5000
CORS_ORIGINS=http://127.0.0.1:5000